# Fortress Stealth Chromium Engine Configuration

# CDP Endpoint
CDP_PORT=9222
CDP_HOST=127.0.0.1

# Persona (default: coherent Windows identity)
# Override any surface with --uxr-* flags at launch
# TILION_NO_DEFAULTS=1  # Skip default persona (bare launch)
# TILION_TZ=America/New_York
# TILION_LANG=en-US

# Persona overrides (passed as --uxr-* flags)
# UXR_TIMEZONE=America/New_York
# UXR_HW_CONCURRENCY=16
# UXR_LANGUAGES=en-US,en
# UXR_SCREEN_WIDTH=1920
# UXR_SCREEN_HEIGHT=1080
# UXR_WEBGL_VENDOR=Google Inc. (NVIDIA)
# UXR_WEBGL_RENDERER=ANGLE (NVIDIA, NVIDIA GeForce RTX 3060 Direct3D11 vs_5_0 ps_5_0)

# Docker
DOCKER_IMAGE=tilion/fortress:latest
